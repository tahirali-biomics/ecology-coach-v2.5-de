/* Cloud vocabulary — Version 2.4 */

.vocabulary-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1rem;
}

.vocabulary-toolbar > div {
  display: grid;
  gap: 0.2rem;
}

.vocabulary-toolbar small {
  color: var(--muted);
}

.vocabulary-grid {
  display: grid;
  grid-template-columns:
    repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.vocabulary-card {
  padding: 1.35rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  min-width: 0;
}

.vocabulary-card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.vocabulary-card-heading h2 {
  margin: 0;
  font: 800 1.25rem Manrope;
  overflow-wrap: anywhere;
}

.vocabulary-card-heading small {
  display: block;
  color: var(--muted);
  margin-top: 0.3rem;
}

.vocabulary-meaning {
  margin: 0;
  line-height: 1.55;
  color: var(--ink);
}

.vocabulary-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
}

.vocabulary-meta span {
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--muted);
  padding: 0.35rem 0.65rem;
  font-size: 0.86rem;
}

.vocabulary-speech-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 0.45rem;
}

.vocabulary-reviewed-button {
  width: 100%;
  margin-top: auto;
}

@media (max-width: 760px) {
  .vocabulary-toolbar {
    align-items: stretch;
    flex-direction: column;
  }

  .vocabulary-toolbar button {
    width: 100%;
  }

  .vocabulary-grid {
    grid-template-columns: 1fr;
  }

  .vocabulary-card-heading {
    flex-direction: column;
  }

  .vocabulary-speech-actions {
    width: 100%;
    justify-content: stretch;
  }

  .vocabulary-speech-actions button {
    flex: 1 1 9rem;
  }
}

